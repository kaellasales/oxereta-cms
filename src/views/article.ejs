<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= article.title %> — NewsDesk</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Georgia', serif;
      background: #f5f5f0;
      color: #1a1a1a;
    }

    .topbar {
      background: #1a1a1a;
      color: #fff;
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 6px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .topbar a { color: #ccc; text-decoration: none; }
    .topbar a:hover { color: #fff; }

    .header {
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      padding: 16px 0 0 0;
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .logo {
      font-family: 'Georgia', serif;
      font-size: 28px;
      font-weight: normal;
      color: #1a1a1a;
      text-decoration: none;
    }
    .logo span { color: #e05c1a; font-weight: bold; }

    .nav {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      gap: 2px;
    }
    .nav a {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #333;
      text-decoration: none;
      padding: 8px 14px;
      border-bottom: 2px solid transparent;
      transition: border-color 0.15s;
    }
    .nav a:hover { border-bottom: 2px solid #1a1a1a; }

    .main {
      max-width: 1100px;
      margin: 36px auto;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 48px;
    }

    /* ARTICLE */
    .article-header { margin-bottom: 24px; }

    .article-category {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      background: #e05c1a;
      color: #fff;
      padding: 3px 8px;
      border-radius: 2px;
      display: inline-block;
      margin-bottom: 14px;
    }

    .article-title {
      font-family: 'Georgia', serif;
      font-size: 30px;
      font-weight: bold;
      line-height: 1.25;
      margin-bottom: 12px;
    }

    .article-subtitle {
      font-family: 'Georgia', serif;
      font-size: 17px;
      color: #555;
      line-height: 1.5;
      margin-bottom: 16px;
      font-style: italic;
    }

    .article-meta {
      font-family: 'Arial', sans-serif;
      font-size: 12px;
      color: #888;
      display: flex;
      gap: 16px;
      padding: 12px 0;
      border-top: 1px solid #e5e5e5;
      border-bottom: 1px solid #e5e5e5;
      margin-bottom: 24px;
    }

    .article-cover {
      width: 100%;
      max-height: 420px;
      object-fit: cover;
      border-radius: 2px;
      margin-bottom: 28px;
      display: block;
    }

    .article-content {
      font-family: 'Georgia', serif;
      font-size: 16px;
      line-height: 1.85;
      color: #222;
    }
    .article-content p { margin-bottom: 20px; }

    .article-tags {
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid #e5e5e5;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }
    .tags-label {
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .tag {
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      background: #eee;
      color: #555;
      padding: 3px 10px;
      border-radius: 20px;
      text-decoration: none;
    }
    .tag:hover { background: #ddd; }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'Arial', sans-serif;
      font-size: 12px;
      color: #888;
      text-decoration: none;
      margin-bottom: 24px;
    }
    .back-link:hover { color: #1a1a1a; }

    /* SIDEBAR */
    .sidebar-title {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #888;
      border-bottom: 1px solid #e0e0e0;
      padding-bottom: 10px;
      margin-bottom: 16px;
    }
    .sidebar-card {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid #eee;
      text-decoration: none;
      color: inherit;
    }
    .sidebar-card:last-child { border-bottom: none; }
    .sidebar-card:hover .sidebar-card-title { color: #e05c1a; }
    .sidebar-img {
      width: 72px;
      height: 52px;
      object-fit: cover;
      border-radius: 2px;
    }
    .sidebar-img-placeholder {
      width: 72px;
      height: 52px;
      background: #e0e0e0;
      border-radius: 2px;
    }
    .sidebar-card-cat {
      font-family: 'Arial', sans-serif;
      font-size: 9px;
      font-weight: bold;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #e05c1a;
      margin-bottom: 3px;
    }
    .sidebar-card-title {
      font-family: 'Georgia', serif;
      font-size: 13px;
      line-height: 1.35;
      transition: color 0.15s;
    }
    .sidebar-card-date {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      color: #bbb;
      margin-top: 4px;
    }
  </style>
</head>
<body>

  <div class="topbar">
    <span style="letter-spacing:2px;font-weight:bold">ÔXERETA</span>
    <a href="/auth/login">Área do jornalista →</a>
  </div>

  <header class="header">
    <div class="header-inner">
      <a href="/" class="logo">ÔXE<span>RETA</span></a>
    </div>
    <nav class="nav">
      <a href="/">Início</a>
    </nav>
  </header>

  <div class="main">

    <!-- ARTICLE CONTENT -->
    <article>
      <a href="/" class="back-link">← Voltar para notícias</a>

      <div class="article-header">
        <% if (article.Category) { %>
          <span class="article-category"><%= article.Category.name %></span>
        <% } %>
        <h1 class="article-title"><%= article.title %></h1>
        <% if (article.subtitle) { %>
          <p class="article-subtitle"><%= article.subtitle %></p>
        <% } %>
        <div class="article-meta">
          <% if (article.author) { %><span>Por <strong><%= article.author.name %></strong></span><% } %>
          <% if (article.publishedAt) { %>
            <span><%= new Date(article.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
          <% } %>
          <span><%= article.views %> visualizações</span>
        </div>
      </div>

      <% if (article.coverImage) { %>
        <img class="article-cover" src="<%= article.coverImage %>" alt="<%= article.title %>">
      <% } %>

      <div class="article-content">
        <%- article.content %>
      </div>

      <% if (article.Tags && article.Tags.length > 0) { %>
        <div class="article-tags">
          <span class="tags-label">Tags:</span>
          <% article.Tags.forEach(tag => { %>
            <a href="/?tag=<%= tag.id %>" class="tag"><%= tag.name %></a>
          <% }) %>
        </div>
      <% } %>
    </article>

    <!-- SIDEBAR -->
    <aside>
      <div class="sidebar-title">Também em destaque</div>
      <% if (typeof featured !== 'undefined' && featured.length > 0) { %>
        <% featured.forEach(a => { %>
          <a href="/artigo/<%= a.slug %>" class="sidebar-card">
            <% if (a.coverImage) { %>
              <img class="sidebar-img" src="<%= a.coverImage %>" alt="">
            <% } else { %>
              <div class="sidebar-img-placeholder"></div>
            <% } %>
            <div>
              <% if (a.Category) { %>
                <div class="sidebar-card-cat"><%= a.Category.name %></div>
              <% } %>
              <div class="sidebar-card-title"><%= a.title %></div>
              <% if (a.publishedAt) { %>
                <div class="sidebar-card-date">
                  <%= new Date(a.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                </div>
              <% } %>
            </div>
          </a>
        <% }) %>
      <% } %>
    </aside>

  </div>

</body>
</html>
