<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= article.title %> — Ôxereta</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Georgia', serif;
      background: #f5f5f0;
      color: #1a1a1a;
    }

    /* ===================== HEADER ===================== */
    .btn-login {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 7px 16px;
      border: 1px solid #1a1a1a;
      border-radius: 4px;
      background: #fff;
      color: #1a1a1a;
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      text-decoration: none;
      transition: all 0.15s;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .btn-login:hover { background: #1a1a1a; color: #fff; }
    .btn-login svg { flex-shrink: 0; }

    .header {
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      padding: 32px 0 0 0;
    }
    .header-logo-row {
      text-align: center;
      margin-bottom: 28px;
    }
    .logo {
      font-family: 'Georgia', serif;
      font-size: 42px;
      font-weight: normal;
      color: #1a1a1a;
      text-decoration: none;
    }
    .logo span { color: #e05c1a; font-weight: bold; }

    .nav-row {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-top: 1px solid #f0f0f0;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      flex: 1;
    }
    .nav-links::-webkit-scrollbar { display: none; }
    .nav-links a {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #333;
      text-decoration: none;
      padding: 14px 16px;
      border-bottom: 3px solid transparent;
      transition: border-color 0.15s, color 0.15s;
      white-space: nowrap;
      display: inline-block;
    }
    .nav-links a:hover { color: #e05c1a; border-bottom-color: #e05c1a; }
    .nav-links a.active { color: #e05c1a; border-bottom-color: #e05c1a; font-weight: bold; }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }
    .search-box {
      display: flex;
      align-items: center;
      border: 1px solid #ddd;
      border-radius: 4px 0 0 4px;
      padding: 6px 12px;
      background: #fafafa;
      width: 220px;
      flex-shrink: 0;
    }
    .search-box input {
      border: none;
      background: transparent;
      outline: none;
      font-size: 13px;
      color: #555;
      width: 100%;
      font-family: 'Arial', sans-serif;
    }
    .search-box svg { color: #aaa; margin-right: 6px; flex-shrink: 0; }
    .btn-search-header {
      background: #1a1a1a;
      color: #fff;
      border: none;
      border-radius: 0 4px 4px 0;
      padding: 7px 14px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      cursor: pointer;
      white-space: nowrap;
    }
    .btn-search-header:hover { background: #333; }

    /* ===================== MAIN ===================== */
    .main {
      max-width: 1100px;
      margin: 36px auto;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 48px;
    }

    /* ===================== ARTICLE ===================== */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'Arial', sans-serif;
      font-size: 12px;
      color: #888;
      text-decoration: none;
      margin-bottom: 24px;
    }
    .back-link:hover { color: #1a1a1a; }

    .article-header { margin-bottom: 24px; }

    .article-category {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      background: #e05c1a;
      color: #fff;
      padding: 3px 8px;
      border-radius: 2px;
      display: inline-block;
      margin-bottom: 14px;
    }

    .article-title {
      font-family: 'Georgia', serif;
      font-size: 30px;
      font-weight: bold;
      line-height: 1.25;
      margin-bottom: 12px;
    }

    .article-subtitle {
      font-family: 'Georgia', serif;
      font-size: 17px;
      color: #555;
      line-height: 1.5;
      margin-bottom: 16px;
      font-style: italic;
    }

    .article-meta {
      font-family: 'Arial', sans-serif;
      font-size: 12px;
      color: #888;
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      padding: 12px 0;
      border-top: 1px solid #e5e5e5;
      border-bottom: 1px solid #e5e5e5;
      margin-bottom: 24px;
    }

    .article-cover {
      width: 100%;
      max-height: 420px;
      object-fit: cover;
      border-radius: 2px;
      margin-bottom: 28px;
      display: block;
    }

    .article-content {
      font-family: 'Georgia', serif;
      font-size: 16px;
      line-height: 1.85;
      color: #222;
    }
    .article-content p { margin-bottom: 20px; }

    .article-tags {
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid #e5e5e5;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }
    .tags-label {
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .tag {
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      background: #eee;
      color: #555;
      padding: 3px 10px;
      border-radius: 20px;
      text-decoration: none;
    }
    .tag:hover { background: #ddd; }

    /* ===================== SIDEBAR ===================== */
    .sidebar-title {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #888;
      border-bottom: 1px solid #e0e0e0;
      padding-bottom: 10px;
      margin-bottom: 16px;
    }
    .sidebar-card {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid #eee;
      text-decoration: none;
      color: inherit;
    }
    .sidebar-card:last-child { border-bottom: none; }
    .sidebar-card:hover .sidebar-card-title { color: #e05c1a; }
    .sidebar-img {
      width: 72px;
      height: 52px;
      object-fit: cover;
      border-radius: 2px;
    }
    .sidebar-img-placeholder {
      width: 72px;
      height: 52px;
      background: #e0e0e0;
      border-radius: 2px;
    }
    .sidebar-card-cat {
      font-family: 'Arial', sans-serif;
      font-size: 9px;
      font-weight: bold;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #e05c1a;
      margin-bottom: 3px;
    }
    .sidebar-card-title {
      font-family: 'Georgia', serif;
      font-size: 13px;
      line-height: 1.35;
      transition: color 0.15s;
    }
    .sidebar-card-date {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      color: #bbb;
      margin-top: 4px;
    }

    /* ===================== FOOTER ===================== */
    .footer {
      background: #1a1a1a;
      color: #ccc;
      margin-top: 64px;
      font-family: 'Arial', sans-serif;
    }
    .footer-top {
      max-width: 1100px;
      margin: 0 auto;
      padding: 48px 24px 40px;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 40px;
    }
    .footer-brand .footer-logo {
      font-family: 'Georgia', serif;
      font-size: 28px;
      color: #fff;
      text-decoration: none;
      display: inline-block;
      margin-bottom: 14px;
    }
    .footer-brand .footer-logo span { color: #e05c1a; font-weight: bold; }
    .footer-brand p {
      font-size: 13px;
      line-height: 1.7;
      color: #999;
      max-width: 280px;
    }
    .footer-social {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }
    .footer-social a {
      width: 34px;
      height: 34px;
      border: 1px solid #444;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #aaa;
      text-decoration: none;
      transition: all 0.15s;
    }
    .footer-social a:hover { border-color: #e05c1a; color: #e05c1a; }
    .footer-col h4 {
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid #333;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col ul li a {
      font-size: 13px;
      color: #999;
      text-decoration: none;
      transition: color 0.15s;
    }
    .footer-col ul li a:hover { color: #e05c1a; }
    .footer-bottom {
      border-top: 1px solid #2e2e2e;
      padding: 16px 24px;
    }
    .footer-bottom-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
      color: #666;
      gap: 16px;
      flex-wrap: wrap;
    }
    .footer-bottom-inner a { color: #666; text-decoration: none; }
    .footer-bottom-inner a:hover { color: #999; }

    /* ===================== RESPONSIVO ===================== */
    @media (max-width: 900px) {
      .main { grid-template-columns: 1fr; gap: 32px; }
      .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
      aside { border-top: 2px solid #1a1a1a; padding-top: 24px; }
    }
    @media (max-width: 700px) {
      .logo { font-size: 28px; }
      .nav-row { padding: 0 16px; }
      .main { padding: 0 16px; margin: 24px auto; }
      .article-title { font-size: 22px; }
    }
    @media (max-width: 480px) {
      .header-logo-row { margin-bottom: 20px; }
      .logo { font-size: 22px; }
      .nav-actions .search-box { width: 140px; }
      .article-title { font-size: 20px; }
      .footer-top { grid-template-columns: 1fr; gap: 28px; }
      .footer-bottom-inner { flex-direction: column; text-align: center; gap: 8px; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="header-logo-row">
      <a href="/" class="logo">ÔXE<span>RETA</span></a>
    </div>
    <div class="nav-row">
      <nav class="nav-links">
        <a href="/">Início</a>
        <% if (typeof categories !== 'undefined') { %>
          <% categories.forEach(cat => { %>
            <a href="/?category=<%= cat.id %>"
               class="<%= article.Category && article.Category.id == cat.id ? 'active' : '' %>">
              <%= cat.name %>
            </a>
          <% }) %>
        <% } %>
      </nav>
      <div class="nav-actions">
        <div class="search-box">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" placeholder="Buscar notícias..." id="topSearch">
        </div>
        <button class="btn-search-header" onclick="doSearch()">Buscar</button>
        <a href="/auth/login" class="btn-login">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          Login
        </a>
      </div>
    </div>
  </header>

  <!-- MAIN -->
  <div class="main">

    <!-- ARTICLE CONTENT -->
    <article>
      <div class="article-header">
        <% if (article.Category) { %>
          <span class="article-category"><%= article.Category.name %></span>
        <% } %>
        <h1 class="article-title"><%= article.title %></h1>
        <% if (article.subtitle) { %>
          <p class="article-subtitle"><%= article.subtitle %></p>
        <% } %>
        <div class="article-meta">
          <% if (article.author) { %><span>Por <strong><%= article.author.name %></strong></span><% } %>
          <% if (article.publishedAt) { %>
            <span><%= new Date(article.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
          <% } %>
          <span><%= article.views %> visualizações</span>
        </div>
      </div>

      <% if (article.coverImage) { %>
        <img class="article-cover" src="<%= article.coverImage %>" alt="<%= article.title %>">
      <% } %>

      <div class="article-content">
        <%- article.content %>
      </div>

      <% if (article.Tags && article.Tags.length > 0) { %>
        <div class="article-tags">
          <span class="tags-label">Tags:</span>
          <% article.Tags.forEach(tag => { %>
            <a href="/?tag=<%= tag.id %>" class="tag"><%= tag.name %></a>
          <% }) %>
        </div>
      <% } %>
    </article>

    <!-- SIDEBAR -->
    <aside>
      <div class="sidebar-title">Também em destaque</div>
      <% if (typeof featured !== 'undefined' && featured.length > 0) { %>
        <% featured.forEach(a => { %>
          <a href="/artigo/<%= a.slug %>" class="sidebar-card">
            <% if (a.coverImage) { %>
              <img class="sidebar-img" src="<%= a.coverImage %>" alt="">
            <% } else { %>
              <div class="sidebar-img-placeholder"></div>
            <% } %>
            <div>
              <% if (a.Category) { %>
                <div class="sidebar-card-cat"><%= a.Category.name %></div>
              <% } %>
              <div class="sidebar-card-title"><%= a.title %></div>
              <% if (a.publishedAt) { %>
                <div class="sidebar-card-date">
                  <%= new Date(a.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                </div>
              <% } %>
            </div>
          </a>
        <% }) %>
      <% } %>
    </aside>

  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-top">

      <div class="footer-brand">
        <a href="/" class="footer-logo">ÔXE<span>RETA</span></a>
        <p>Jornalismo independente do Nordeste para o Brasil. Notícias com contexto, sem sensacionalismo.</p>
        <div class="footer-social">
          <a href="#" title="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" title="Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4l16 16M4 20L20 4"/>
            </svg>
          </a>
          <a href="#" title="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" title="YouTube">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Editorias</h4>
        <ul>
          <% if (typeof categories !== 'undefined') { %>
            <% categories.forEach(cat => { %>
              <li><a href="/?category=<%= cat.id %>"><%= cat.name %></a></li>
            <% }) %>
          <% } %>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Institucional</h4>
        <ul>
          <li><a href="#">Sobre nós</a></li>
          <li><a href="#">Equipe</a></li>
          <li><a href="#">Política editorial</a></li>
          <li><a href="#">Trabalhe conosco</a></li>
          <li><a href="#">Anuncie</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contato</h4>
        <ul>
          <li><a href="#">redacao@oxereta.com.br</a></li>
          <li><a href="#">Fale conosco</a></li>
          <li><a href="#">Denúncias</a></li>
          <li><a href="/auth/login">Área da redação</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <span>© <%= new Date().getFullYear() %> Ôxereta. Todos os direitos reservados.</span>
        <span>
          <a href="#">Política de Privacidade</a> ·
          <a href="#">Termos de Uso</a> ·
          <a href="#">Cookies</a>
        </span>
      </div>
    </div>
  </footer>

  <script>
    function doSearch() {
      const val = document.getElementById('topSearch').value;
      window.location.href = '/?search=' + encodeURIComponent(val);
    }
    document.getElementById('topSearch').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') doSearch();
    });
  </script>

</body>
</html>
