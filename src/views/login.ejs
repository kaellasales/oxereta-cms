<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Login — ÔXereta</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Arial', sans-serif; background: #f5f5f0; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar { background: #1a1a1a; color: #fff; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; padding: 6px 24px; }
    .container { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 24px; }
    .card { background: #fff; border: 1px solid #e0e0e0; border-radius: 4px; padding: 40px; width: 100%; max-width: 380px; }
    .logo { font-family: 'Georgia', serif; font-size: 24px; text-align: center; margin-bottom: 28px; }
    .logo span { color: #e05c1a; font-weight: bold; }
    .label { font-size: 12px; color: #555; margin-bottom: 5px; display: block; }
    .input { width: 100%; border: 1px solid #ddd; border-radius: 3px; padding: 9px 12px; font-size: 14px; margin-bottom: 16px; outline: none; }
    .input:focus { border-color: #999; }
    .btn { width: 100%; background: #1a1a1a; color: #fff; border: none; border-radius: 3px; padding: 10px; font-size: 14px; cursor: pointer; }
    .btn:hover { background: #333; }
    .error { background: #fef2f2; border: 1px solid #fca5a5; color: #dc2626; padding: 10px 12px; border-radius: 3px; font-size: 13px; margin-bottom: 16px; }
    .back { display: block; text-align: center; margin-top: 16px; font-size: 12px; color: #888; text-decoration: none; }
    .back:hover { color: #1a1a1a; }
  </style>
</head>
<body>
  <div class="topbar">ÔXERETA</div>
  <div class="container">
    <div class="card">
      <div class="logo">ÔXE<span>RETA</span></div>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form method="POST" action="/auth/login">
        <label class="label">E-mail</label>
        <input class="input" type="email" name="email" required placeholder="seu@email.com">
        <label class="label">Senha</label>
        <input class="input" type="password" name="password" required placeholder="••••••••">
        <button class="btn" type="submit">Entrar</button>
      </form>
      <a href="/" class="back">← Voltar para o site</a>
    </div>
  </div>
</body>
</html>