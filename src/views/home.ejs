<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NewsDesk</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Georgia', serif;
      background: #f5f5f0;
      color: #1a1a1a;
    }

    /* TOP BAR */
    .topbar {
      background: #1a1a1a;
      color: #fff;
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 6px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .topbar a {
      color: #ccc;
      text-decoration: none;
    }
    .topbar a:hover { color: #fff; }

    /* HEADER */
    .header {
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      padding: 16px 0 0 0;
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .logo {
      font-family: 'Georgia', serif;
      font-size: 28px;
      font-weight: normal;
      color: #1a1a1a;
      text-decoration: none;
    }
    .logo span { color: #e05c1a; font-weight: bold; }

    .search-box {
      display: flex;
      align-items: center;
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 6px 12px;
      background: #fafafa;
      width: 260px;
    }
    .search-box input {
      border: none;
      background: transparent;
      outline: none;
      font-size: 13px;
      color: #555;
      width: 100%;
      font-family: 'Arial', sans-serif;
    }
    .search-box svg { color: #aaa; margin-right: 6px; flex-shrink: 0; }

    /* NAV */
    .nav {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      gap: 2px;
    }
    .nav a {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #333;
      text-decoration: none;
      padding: 8px 14px;
      border-bottom: 2px solid transparent;
      transition: border-color 0.15s;
    }
    .nav a:hover, .nav a.active { border-bottom: 2px solid #1a1a1a; }

    /* MAIN */
    .main {
      max-width: 1100px;
      margin: 32px auto;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 40px;
    }

    /* SECTION TITLE */
    .section-title {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 8px;
      margin-bottom: 20px;
    }
    .section-title h2 {
      font-family: 'Georgia', serif;
      font-size: 22px;
      font-weight: normal;
    }
    .section-title span {
      font-family: 'Arial', sans-serif;
      font-size: 12px;
      color: #888;
    }

    /* FILTERS */
    .filters {
      display: flex;
      gap: 8px;
      margin-bottom: 24px;
      align-items: center;
    }
    .filters form { display: flex; gap: 8px; width: 100%; align-items: center; }
    .filter-search {
      flex: 1;
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 8px 12px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      background: #fafafa;
      outline: none;
    }
    .filter-search:focus { border-color: #999; }
    .btn-search {
      background: #1a1a1a;
      color: #fff;
      border: none;
      border-radius: 4px;
      padding: 8px 18px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      cursor: pointer;
      white-space: nowrap;
    }
    .btn-search:hover { background: #333; }
    .filter-select {
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 8px 12px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      background: #fafafa;
      outline: none;
      cursor: pointer;
    }

    /* ARTICLE CARDS */
    .articles-grid { display: flex; flex-direction: column; gap: 0; }

    .article-card {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 16px;
      padding: 20px 0;
      border-bottom: 1px solid #e5e5e5;
      text-decoration: none;
      color: inherit;
    }
    .article-card:first-child { padding-top: 0; }
    .article-card:hover .card-title { color: #e05c1a; }

    .card-img {
      width: 200px;
      height: 130px;
      object-fit: cover;
      border-radius: 2px;
      background: #ddd;
      display: block;
    }
    .card-img-placeholder {
      width: 200px;
      height: 130px;
      background: #e0e0e0;
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #aaa;
      font-size: 12px;
    }

    .card-body { display: flex; flex-direction: column; justify-content: flex-start; gap: 6px; }

    .card-category {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      background: #e05c1a;
      color: #fff;
      padding: 2px 7px;
      border-radius: 2px;
      display: inline-block;
      width: fit-content;
    }

    .card-title {
      font-family: 'Georgia', serif;
      font-size: 17px;
      font-weight: bold;
      line-height: 1.3;
      transition: color 0.15s;
    }

    .card-subtitle {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #666;
      line-height: 1.5;
    }

    .card-meta {
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      color: #aaa;
      margin-top: auto;
    }

    /* PAGINATION */
    .pagination {
      display: flex;
      gap: 6px;
      margin-top: 28px;
      align-items: center;
    }
    .pagination a, .pagination span {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      padding: 6px 12px;
      border: 1px solid #ddd;
      border-radius: 3px;
      text-decoration: none;
      color: #333;
      background: #fff;
    }
    .pagination a:hover { background: #f0f0f0; }
    .pagination .active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }

    /* SIDEBAR */
    .sidebar {}
    .sidebar-title {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #888;
      border-bottom: 1px solid #e0e0e0;
      padding-bottom: 10px;
      margin-bottom: 16px;
    }

    .sidebar-card {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid #eee;
      text-decoration: none;
      color: inherit;
    }
    .sidebar-card:last-child { border-bottom: none; }
    .sidebar-card:hover .sidebar-card-title { color: #e05c1a; }

    .sidebar-img {
      width: 72px;
      height: 52px;
      object-fit: cover;
      border-radius: 2px;
      background: #ddd;
    }
    .sidebar-img-placeholder {
      width: 72px;
      height: 52px;
      background: #e0e0e0;
      border-radius: 2px;
    }

    .sidebar-card-cat {
      font-family: 'Arial', sans-serif;
      font-size: 9px;
      font-weight: bold;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #e05c1a;
      margin-bottom: 3px;
    }
    .sidebar-card-title {
      font-family: 'Georgia', serif;
      font-size: 13px;
      line-height: 1.35;
      transition: color 0.15s;
    }
    .sidebar-card-date {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      color: #bbb;
      margin-top: 4px;
    }

    /* EMPTY STATE */
    .empty {
      text-align: center;
      padding: 60px 20px;
      color: #aaa;
      font-family: 'Arial', sans-serif;
      font-size: 14px;
    }
  </style>
</head>
<body>

  <!-- TOP BAR -->
  <div class="topbar">
    <span style="letter-spacing:2px;font-weight:bold">ÔXERETA</span>
    <a href="/auth/login" target="_self">Área do jornalista →</a>
  </div>

  <!-- HEADER -->
  <header class="header">
    <div class="header-inner">
      <a href="/" class="logo">ÔXE<span>RETA</span></a>
      <div class="search-box">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" placeholder="Buscar notícias..." id="topSearch">
      </div>
    </div>
    <nav class="nav">
      <a href="/" class="active">Início</a>
      <% if (typeof categories !== 'undefined') { %>
        <% categories.forEach(cat => { %>
          <a href="/?category=<%= cat.id %>"><%= cat.name %></a>
        <% }) %>
      <% } %>
    </nav>
  </header>

  <!-- MAIN CONTENT -->
  <div class="main">

    <!-- LEFT: ARTICLES -->
    <div>
      <div class="section-title">
        <h2>Últimas notícias</h2>
        <span><%= totalCount %> artigos</span>
      </div>

    <!-- FILTERS -->
    <div class="filters">
      <form method="GET" action="/">
        <input class="filter-search" type="text" name="search"
            value="<%= typeof search !== 'undefined' ? search || '' : '' %>"
            placeholder="Buscar notícias...">
          <button class="btn-search" type="submit">Buscar</button>
          <select class="filter-select" name="category" onchange="this.form.submit()">
            <option value="">Todas as categorias</option>
            <% if (typeof categories !== 'undefined') { %>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>"
                  <%= (typeof selectedCategory !== 'undefined' && selectedCategory == cat.id) ? 'selected' : '' %>>
                  <%= cat.name %>
                </option>
              <% }) %>
            <% } %>
          </select>
          <select class="filter-select" name="tag" onchange="this.form.submit()">
            <option value="">Todas as tags</option>
            <% if (typeof tags !== 'undefined') { %>
              <% tags.forEach(t => { %>
                <option value="<%= t.id %>"
                  <%= (typeof selectedTag !== 'undefined' && selectedTag == t.id) ? 'selected' : '' %>>
                  <%= t.name %>
                </option>
              <% }) %>
            <% } %>
          </select>
          <select class="filter-select" name="order" onchange="this.form.submit()">
            <option value="recent" <%= (typeof order === 'undefined' || order === 'recent') ? 'selected' : '' %>>Mais recentes</option>
            <option value="views" <%= (typeof order !== 'undefined' && order === 'views') ? 'selected' : '' %>>Mais lidos</option>
          </select>
          <input class="filter-search" type="date" name="dateFrom"
            value="<%= typeof dateFrom !== 'undefined' ? dateFrom || '' : '' %>"
            style="max-width:150px">
          <input class="filter-search" type="date" name="dateTo"
            value="<%= typeof dateTo !== 'undefined' ? dateTo || '' : '' %>"
            style="max-width:150px">
        </form>
      </div>

      <!-- ARTICLES LIST -->
      <div class="articles-grid">
        <% if (articles.length === 0) { %>
          <div class="empty">Nenhum artigo encontrado.</div>
        <% } else { %>
          <% articles.forEach(article => { %>
            <a href="/artigo/<%= article.slug %>" class="article-card">
              <% if (article.coverImage) { %>
                <img class="card-img" src="<%= article.coverImage %>" alt="<%= article.title %>">
              <% } else { %>
                <div class="card-img-placeholder">sem imagem</div>
              <% } %>
              <div class="card-body">
                <% if (article.Category) { %>
                  <span class="card-category"><%= article.Category.name %></span>
                <% } %>
                <div class="card-title"><%= article.title %></div>
                <% if (article.subtitle) { %>
                  <div class="card-subtitle"><%= article.subtitle %></div>
                <% } %>
                <div class="card-meta">
                  <%= article.author ? article.author.name : '' %>
                  <% if (article.publishedAt) { %>
                    · <%= new Date(article.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                  <% } %>
                </div>
              </div>
            </a>
          <% }) %>
        <% } %>
      </div>

      <!-- PAGINATION -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (page > 1) { %>
            <a href="?page=<%= page - 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>">← Anterior</a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === page) { %>
              <span class="active"><%= i %></span>
            <% } else { %>
              <a href="?page=<%= i %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>"><%= i %></a>
            <% } %>
          <% } %>
          <% if (page < totalPages) { %>
            <a href="?page=<%= page + 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>">Próxima →</a>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- RIGHT: SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-title">Também em destaque</div>
      <% if (typeof featured !== 'undefined' && featured.length > 0) { %>
        <% featured.forEach(article => { %>
          <a href="/artigo/<%= article.slug %>" class="sidebar-card">
            <% if (article.coverImage) { %>
              <img class="sidebar-img" src="<%= article.coverImage %>" alt="">
            <% } else { %>
              <div class="sidebar-img-placeholder"></div>
            <% } %>
            <div>
              <% if (article.Category) { %>
                <div class="sidebar-card-cat"><%= article.Category.name %></div>
              <% } %>
              <div class="sidebar-card-title"><%= article.title %></div>
              <% if (article.publishedAt) { %>
                <div class="sidebar-card-date">
                  <%= new Date(article.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                </div>
              <% } %>
            </div>
          </a>
        <% }) %>
      <% } %>
    </aside>

  </div>

  <script>
    document.getElementById('topSearch').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        window.location.href = '/?search=' + encodeURIComponent(this.value);
      }
    });
  </script>

</body>
</html>
