<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ÔXereta</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Georgia', serif;
      background: #f5f5f0;
      color: #1a1a1a;
    }

    /* BOTÃO LOGIN */
    .btn-login {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 7px 16px;
      border: 1px solid #1a1a1a;
      border-radius: 4px;
      background: #fff;
      color: #1a1a1a;
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      text-decoration: none;
      transition: all 0.15s;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .btn-login:hover { background: #1a1a1a; color: #fff; }
    .btn-login svg { flex-shrink: 0; }

    /* HEADER */
    .header {
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      padding: 32px 0 0 0;
    }

    /* Logo centralizada */
    .header-logo-row {
      text-align: center;
      margin-bottom: 28px;
    }
    .logo {
      font-family: 'Georgia', serif;
      font-size: 42px;
      font-weight: normal;
      color: #1a1a1a;
      text-decoration: none;
    }
    .logo span { color: #e05c1a; font-weight: bold; }

    /* Linha com busca + login */
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
      margin-bottom: 14px;
    }

    /* NAV — agora na mesma linha que busca e login */
    .nav {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      gap: 2px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .nav::-webkit-scrollbar { display: none; }

    /* wrapper que agrupa nav + busca + login na mesma linha */
    .nav-row {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-top: 1px solid #f0f0f0;
    }

    .nav-links a {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #333;
      text-decoration: none;
      padding: 14px 16px;
      border-bottom: 3px solid transparent;
      transition: border-color 0.15s, color 0.15s;
      white-space: nowrap;
      display: inline-block;
    }
    .nav-links a:hover { color: #e05c1a; border-bottom-color: #e05c1a; }
    .nav-links a.active { color: #e05c1a; border-bottom-color: #e05c1a; font-weight: bold; }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      flex: 1;
    }
    .nav-links::-webkit-scrollbar { display: none; }
    .nav-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .nav a {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #333;
      text-decoration: none;
      padding: 14px 16px;
      border-bottom: 3px solid transparent;
      white-space: nowrap;
    }

    .search-box {
      display: flex;
      align-items: center;
      border: 1px solid #ddd;
      border-radius: 4px 0 0 4px;
      padding: 6px 12px;
      background: #fafafa;
      width: 220px;
      flex-shrink: 0;
    }
    .search-box input {
      border: none;
      background: transparent;
      outline: none;
      font-size: 13px;
      color: #555;
      width: 100%;
      font-family: 'Arial', sans-serif;
    }
    .search-box svg { color: #aaa; margin-right: 6px; flex-shrink: 0; }

    .btn-search-header {
      background: #1a1a1a;
      color: #fff;
      border: none;
      border-radius: 0 4px 4px 0;
      padding: 7px 14px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      cursor: pointer;
      white-space: nowrap;
    }
    .btn-search-header:hover { background: #333; }
    .nav a {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #333;
      text-decoration: none;
      padding: 8px 14px;
      border-bottom: 2px solid transparent;
      transition: border-color 0.15s;
      white-space: nowrap;
    }
    .nav a:hover, .nav a.active { border-bottom: 2px solid #1a1a1a; }

    /* MAIN */
    .main {
      max-width: 1100px;
      margin: 32px auto;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 40px;
    }

    /* SECTION TITLE */
    .section-title {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 8px;
      margin-bottom: 20px;
    }
    .section-title h2 {
      font-family: 'Georgia', serif;
      font-size: 22px;
      font-weight: normal;
    }
    .section-title span {
      font-family: 'Arial', sans-serif;
      font-size: 12px;
      color: #888;
    }

    /* FILTERS */
    .filters { display: flex; gap: 8px; margin-bottom: 24px; }
    .filters form {
      display: flex;
      gap: 8px;
      width: 100%;
      align-items: center;
      flex-wrap: wrap;
    }
    .filter-search {
      flex: 1;
      min-width: 120px;
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 8px 12px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      background: #fafafa;
      outline: none;
    }
    .filter-search:focus { border-color: #999; }
    .btn-search {
      background: #1a1a1a;
      color: #fff;
      border: none;
      border-radius: 4px;
      padding: 8px 18px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      cursor: pointer;
      white-space: nowrap;
    }
    .btn-search:hover { background: #333; }
    .filter-select {
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 8px 12px;
      font-size: 13px;
      font-family: 'Arial', sans-serif;
      background: #fafafa;
      outline: none;
      cursor: pointer;
    }

    /* ARTICLE CARDS */
    .articles-grid { display: flex; flex-direction: column; gap: 0; }

    .article-card {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 16px;
      padding: 20px 0;
      border-bottom: 1px solid #e5e5e5;
      text-decoration: none;
      color: inherit;
    }
    .article-card:first-child { padding-top: 0; }
    .article-card:hover .card-title { color: #e05c1a; }

    .card-img {
      width: 200px;
      height: 130px;
      object-fit: cover;
      border-radius: 2px;
      background: #ddd;
      display: block;
    }
    .card-img-placeholder {
      width: 200px;
      height: 130px;
      background: #e0e0e0;
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #aaa;
      font-size: 12px;
    }

    .card-body { display: flex; flex-direction: column; justify-content: flex-start; gap: 6px; }

    .card-category {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      background: #e05c1a;
      color: #fff;
      padding: 2px 7px;
      border-radius: 2px;
      display: inline-block;
      width: fit-content;
    }

    .card-title {
      font-family: 'Georgia', serif;
      font-size: 17px;
      font-weight: bold;
      line-height: 1.3;
      transition: color 0.15s;
    }

    .card-subtitle {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      color: #666;
      line-height: 1.5;
    }

    .card-meta {
      font-family: 'Arial', sans-serif;
      font-size: 11px;
      color: #aaa;
      margin-top: auto;
    }

    /* PAGINATION */
    .pagination {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 28px;
      align-items: center;
    }
    .pagination a, .pagination span {
      font-family: 'Arial', sans-serif;
      font-size: 13px;
      padding: 6px 12px;
      border: 1px solid #ddd;
      border-radius: 3px;
      text-decoration: none;
      color: #333;
      background: #fff;
    }
    .pagination a:hover { background: #f0f0f0; }
    .pagination .active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }

    /* SIDEBAR */
    .sidebar {}
    .sidebar-title {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #888;
      border-bottom: 1px solid #e0e0e0;
      padding-bottom: 10px;
      margin-bottom: 16px;
    }

    .sidebar-card {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid #eee;
      text-decoration: none;
      color: inherit;
    }
    .sidebar-card:last-child { border-bottom: none; }
    .sidebar-card:hover .sidebar-card-title { color: #e05c1a; }

    .sidebar-img {
      width: 72px;
      height: 52px;
      object-fit: cover;
      border-radius: 2px;
      background: #ddd;
    }
    .sidebar-img-placeholder {
      width: 72px;
      height: 52px;
      background: #e0e0e0;
      border-radius: 2px;
    }

    .sidebar-card-cat {
      font-family: 'Arial', sans-serif;
      font-size: 9px;
      font-weight: bold;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #e05c1a;
      margin-bottom: 3px;
    }
    .sidebar-card-title {
      font-family: 'Georgia', serif;
      font-size: 13px;
      line-height: 1.35;
      transition: color 0.15s;
    }
    .sidebar-card-date {
      font-family: 'Arial', sans-serif;
      font-size: 10px;
      color: #bbb;
      margin-top: 4px;
    }

    /* EMPTY STATE */
    .empty {
      text-align: center;
      padding: 60px 20px;
      color: #aaa;
      font-family: 'Arial', sans-serif;
      font-size: 14px;
    }

    /* FOOTER */
    .footer {
      background: #1a1a1a;
      color: #ccc;
      margin-top: 64px;
      font-family: 'Arial', sans-serif;
    }
    .footer-top {
      max-width: 1100px;
      margin: 0 auto;
      padding: 48px 24px 40px;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 40px;
    }
    .footer-brand .footer-logo {
      font-family: 'Georgia', serif;
      font-size: 28px;
      color: #fff;
      text-decoration: none;
      display: inline-block;
      margin-bottom: 14px;
    }
    .footer-brand .footer-logo span { color: #e05c1a; font-weight: bold; }
    .footer-brand p {
      font-size: 13px;
      line-height: 1.7;
      color: #999;
      max-width: 280px;
    }
    .footer-social {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }
    .footer-social a {
      width: 34px;
      height: 34px;
      border: 1px solid #444;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #aaa;
      text-decoration: none;
      transition: all 0.15s;
    }
    .footer-social a:hover { border-color: #e05c1a; color: #e05c1a; }

    .footer-col h4 {
      font-size: 10px;
      font-weight: bold;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid #333;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col ul li a {
      font-size: 13px;
      color: #999;
      text-decoration: none;
      transition: color 0.15s;
    }
    .footer-col ul li a:hover { color: #e05c1a; }

    .footer-bottom {
      border-top: 1px solid #2e2e2e;
      padding: 16px 24px;
    }
    .footer-bottom-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
      color: #666;
      gap: 16px;
      flex-wrap: wrap;
    }
    .footer-bottom-inner a { color: #666; text-decoration: none; }
    .footer-bottom-inner a:hover { color: #999; }

    @media (max-width: 900px) {
      .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
    }
    @media (max-width: 480px) {
      .footer-top { grid-template-columns: 1fr; gap: 28px; }
      .footer-bottom-inner { flex-direction: column; text-align: center; gap: 8px; }
    }

    /* ===================== RESPONSIVO ===================== */

    /* Tablet: <= 900px — sidebar vai para baixo */
    @media (max-width: 900px) {
      .main {
        grid-template-columns: 1fr;
        gap: 32px;
      }
      .sidebar {
        border-top: 2px solid #1a1a1a;
        padding-top: 24px;
      }
    }

    /* Tablet médio: <= 700px */
    @media (max-width: 700px) {
      .topbar { font-size: 10px; padding: 6px 16px; }

      .header-inner { padding: 0 16px; margin-bottom: 10px; }
      .logo { font-size: 22px; }
      .search-box { width: 100%; }

      .nav { padding: 0 16px; }

      .main { padding: 0 16px; margin: 24px auto; }

      /* card vira coluna no tablet */
      .article-card {
        grid-template-columns: 140px 1fr;
        gap: 12px;
      }
      .card-img, .card-img-placeholder {
        width: 140px;
        height: 100px;
      }
      .card-title { font-size: 15px; }
    }

    /* Mobile: <= 480px */
    @media (max-width: 480px) {
      .topbar { flex-direction: column; gap: 4px; text-align: center; }

      .header-inner { flex-direction: column; align-items: flex-start; gap: 10px; }
      .search-box { width: 100%; }

      /* card vira empilhado */
      .article-card {
        grid-template-columns: 1fr;
        gap: 10px;
      }
      .card-img {
        width: 100%;
        height: 180px;
      }
      .card-img-placeholder {
        width: 100%;
        height: 180px;
      }

      .card-title { font-size: 16px; }

      /* filtros empilham */
      .filters form { flex-direction: column; align-items: stretch; }
      .filter-search,
      .filter-select,
      .btn-search { width: 100%; }

      .section-title h2 { font-size: 18px; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <!-- Logo centralizada -->
    <div class="header-logo-row">
      <a href="/" class="logo">ÔXE<span>RETA</span></a>
    </div>

    <!-- Nav + busca + login na mesma linha -->
    <div class="nav-row">
      <nav class="nav-links">
        <a href="/" class="<%= !selectedCategory ? 'active' : '' %>">Início</a>
        <% if (typeof categories !== 'undefined') { %>
          <% categories.forEach(cat => { %>
            <a href="/?category=<%= cat.id %>"
               class="<%= (typeof selectedCategory !== 'undefined' && selectedCategory == cat.id) ? 'active' : '' %>">
              <%= cat.name %>
            </a>
          <% }) %>
        <% } %>
      </nav>
      <div class="nav-actions">
        <div class="search-box">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" placeholder="Buscar notícias..." id="topSearch">
        </div>
        <button class="btn-search-header" onclick="doSearch()">Buscar</button>
        <a href="/auth/login" class="btn-login">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          Login
        </a>
      </div>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <div class="main">

    <!-- LEFT: ARTICLES -->
    <div>
      <div class="section-title">
        <h2>Últimas notícias</h2>
        <span><%= totalCount %> artigos</span>
      </div>

      <!-- FILTERS -->
      <div class="filters">
        <form method="GET" action="/">
          <select class="filter-select" name="category" onchange="this.form.submit()">
            <option value="">Todas as categorias</option>
            <% if (typeof categories !== 'undefined') { %>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>"
                  <%= (typeof selectedCategory !== 'undefined' && selectedCategory == cat.id) ? 'selected' : '' %>>
                  <%= cat.name %>
                </option>
              <% }) %>
            <% } %>
          </select>
          <select class="filter-select" name="tag" onchange="this.form.submit()">
            <option value="">Todas as tags</option>
            <% if (typeof tags !== 'undefined') { %>
              <% tags.forEach(t => { %>
                <option value="<%= t.id %>"
                  <%= (typeof selectedTag !== 'undefined' && selectedTag == t.id) ? 'selected' : '' %>>
                  <%= t.name %>
                </option>
              <% }) %>
            <% } %>
          </select>
          <select class="filter-select" name="order" onchange="this.form.submit()">
            <option value="recent" <%= (typeof order === 'undefined' || order === 'recent') ? 'selected' : '' %>>Mais recentes</option>
            <option value="views" <%= (typeof order !== 'undefined' && order === 'views') ? 'selected' : '' %>>Mais lidos</option>
          </select>
          <input class="filter-search" type="date" name="dateFrom"
            value="<%= typeof dateFrom !== 'undefined' ? dateFrom || '' : '' %>"
            style="max-width:150px">
          <input class="filter-search" type="date" name="dateTo"
            value="<%= typeof dateTo !== 'undefined' ? dateTo || '' : '' %>"
            style="max-width:150px">
          <!-- campo oculto para preservar busca do header ao filtrar -->
          <input type="hidden" name="search" value="<%= typeof search !== 'undefined' ? search || '' : '' %>">
        </form>
      </div>

      <!-- ARTICLES LIST -->
      <div class="articles-grid">
        <% if (articles.length === 0) { %>
          <div class="empty">Nenhum artigo encontrado.</div>
        <% } else { %>
          <% articles.forEach(article => { %>
            <a href="/artigo/<%= article.slug %>" class="article-card">
              <% if (article.coverImage) { %>
                <img class="card-img" src="<%= article.coverImage %>" alt="<%= article.title %>">
              <% } else { %>
                <div class="card-img-placeholder">sem imagem</div>
              <% } %>
              <div class="card-body">
                <% if (article.Category) { %>
                  <span class="card-category"><%= article.Category.name %></span>
                <% } %>
                <div class="card-title"><%= article.title %></div>
                <% if (article.subtitle) { %>
                  <div class="card-subtitle"><%= article.subtitle %></div>
                <% } %>
                <div class="card-meta">
                  <%= article.author ? article.author.name : '' %>
                  <% if (article.publishedAt) { %>
                    · <%= new Date(article.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                  <% } %>
                </div>
              </div>
            </a>
          <% }) %>
        <% } %>
      </div>

      <!-- PAGINATION -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (page > 1) { %>
            <a href="?page=<%= page - 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>">← Anterior</a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === page) { %>
              <span class="active"><%= i %></span>
            <% } else { %>
              <a href="?page=<%= i %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>"><%= i %></a>
            <% } %>
          <% } %>
          <% if (page < totalPages) { %>
            <a href="?page=<%= page + 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>">Próxima →</a>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- RIGHT: SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-title">Também em destaque</div>
      <% if (typeof featured !== 'undefined' && featured.length > 0) { %>
        <% featured.forEach(article => { %>
          <a href="/artigo/<%= article.slug %>" class="sidebar-card">
            <% if (article.coverImage) { %>
              <img class="sidebar-img" src="<%= article.coverImage %>" alt="">
            <% } else { %>
              <div class="sidebar-img-placeholder"></div>
            <% } %>
            <div>
              <% if (article.Category) { %>
                <div class="sidebar-card-cat"><%= article.Category.name %></div>
              <% } %>
              <div class="sidebar-card-title"><%= article.title %></div>
              <% if (article.publishedAt) { %>
                <div class="sidebar-card-date">
                  <%= new Date(article.publishedAt).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                </div>
              <% } %>
            </div>
          </a>
        <% }) %>
      <% } %>
    </aside>

  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-top">

      <!-- Coluna marca -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">ÔXE<span>RETA</span></a>
        <p>Jornalismo independente do Nordeste para o Brasil. Notícias com contexto, sem sensacionalismo.</p>
        <div class="footer-social">
          <!-- Instagram -->
          <a href="#" title="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <!-- Twitter/X -->
          <a href="#" title="Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4l16 16M4 20L20 4"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a href="#" title="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a href="#" title="YouTube">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Editorias -->
      <div class="footer-col">
        <h4>Editorias</h4>
        <ul>
          <% if (typeof categories !== 'undefined') { %>
            <% categories.forEach(cat => { %>
              <li><a href="/?category=<%= cat.id %>"><%= cat.name %></a></li>
            <% }) %>
          <% } %>
        </ul>
      </div>

      <!-- Institucional -->
      <div class="footer-col">
        <h4>Institucional</h4>
        <ul>
          <li><a href="#">Sobre nós</a></li>
          <li><a href="#">Equipe</a></li>
          <li><a href="#">Política editorial</a></li>
          <li><a href="#">Trabalhe conosco</a></li>
          <li><a href="#">Anuncie</a></li>
        </ul>
      </div>

      <!-- Contato -->
      <div class="footer-col">
        <h4>Contato</h4>
        <ul>
          <li><a href="#">redacao@oxereta.com.br</a></li>
          <li><a href="#">Fale conosco</a></li>
          <li><a href="#">Denúncias</a></li>
          <li><a href="/auth/login">Área da redação</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <span>© <%= new Date().getFullYear() %> Ôxereta. Todos os direitos reservados.</span>
        <span>
          <a href="#">Política de Privacidade</a> ·
          <a href="#">Termos de Uso</a> ·
          <a href="#">Cookies</a>
        </span>
      </div>
    </div>
  </footer>

  <script>
    function doSearch() {
      const val = document.getElementById('topSearch').value;
      window.location.href = '/?search=' + encodeURIComponent(val);
    }
    document.getElementById('topSearch').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') doSearch();
    });
  </script>

</body>
</html>
